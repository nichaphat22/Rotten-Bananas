<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- logo -->
    <link rel="icon" type="image/png"
        href="https://firebasestorage.googleapis.com/v0/b/mbwproject-78d38.appspot.com/o/Logo.png?alt=media&token=de0aac26-de6a-43c0-839d-9032323646cd&_gl=1*15y48q1*_ga*MTg1NDY0MDk2OC4xNjk2MzM4MjQ3*_ga_CW55HF8NVT*MTY5NjMzODI0Ny4xLjEuMTY5NjMzODYxNy40NC4wLjA." />
    <!-- bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <!-- css -->
    <link rel="stylesheet" href="/stylesheets/login.css">
    <title>Rotten Bananas - Login</title>
   
</head>
<body>
    <%- include('./partials/nav.ejs') %>
    <div class="contentlogin">
        <div class="container text-center ">
            <div class="row justify-content-md-center">
                <div class="col-lg-6 mt-5  ">
                    <img src="https://firebasestorage.googleapis.com/v0/b/mbwproject-78d38.appspot.com/o/bananaa.png?alt=media&token=b2f045a2-9bb8-4565-b68a-a43029cea81a&_gl=1*6oxkeb*_ga*MTg1NDY0MDk2OC4xNjk2MzM4MjQ3*_ga_CW55HF8NVT*MTY5NjMzODI0Ny4xLjEuMTY5NjMzOTQ3MC41MS4wLjA."
                        alt="bananarotten" class="bnnlogin mb-5 ">
                    <p class="undr ">คุณไม่ได้เป็นสมาชิกใช่ไหม? <a class="yllw" href="/register">ลงทะเบียนที่นี่</a>
                    </p>
                </div>
                <div class="col-lg-6 mt-5 ">
                    <img src="https://firebasestorage.googleapis.com/v0/b/mbwproject-78d38.appspot.com/o/Rottenblack.png?alt=media&token=5c2b8816-b7b6-4614-9b4f-482380fd1e3f&_gl=1*10cx9gg*_ga*MTg1NDY0MDk2OC4xNjk2MzM4MjQ3*_ga_CW55HF8NVT*MTY5NjQ0NTY4OC4xMC4xLjE2OTY0NDU4NzguMTYuMC4w&fbclid=IwAR08ktD3iwvqJA7a8fODbVcUdbrwYxmEwLCoY8OUxUykgKXO4NmYiaEq50c."
                        alt="logo-Bananas Rotten" class="lgbnn ">
                    <p class="logintt">เข้าสู่ระบบ</p>
                    <div class="loginn">
                        <form>
                            <div class="login-form">
                                <div class="login-form">
                                    <div class="form-group">
                                        <label class="form-control-label  " style="font-size: 5em;">Email</label>
                                        <input type="email" class="form-control"  name="email" required>
                                        <div class="email error"></div>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-control-label " style="font-size: 5em;">รหัสผ่าน</label>
                                        <input type="password" class="form-control" name="password" required>
                                        <div class="password error"></div>
                                    </div>
                                </div>
                                <div class="login-btm login-button form-group">
                                    <button id="login-button" type="submit" class="btn btn-outline-yellow ps-3 pe-3 pt-2 pb-2">เข้าสู่ระบบ</button>

                                </div>
                            </div>
                        </form>
                    </div>

                </div>

            </div>
        </div>
    






    <script>
        const form = document.querySelector('.contentlogin form');
        const emailError = document.querySelector('.email.error');
        const passwordError = document.querySelector('.password.error');
        const submitButton = document.querySelector('#login-button');

        submitButton.addEventListener('click', async (e) => {
            e.preventDefault();

            // Reset errors
            emailError.textContent = '';
            passwordError.textContent = '';

            // Get the values
            const email = form.email.value;
            const password = form.password.value;
            console.log(email, password); // ตรวจสอบให้แน่ใจว่าค่าถูกต้อง

            try {
                const res = await fetch('/login', {
                    method: 'POST',
                    body: JSON.stringify({ email, password }),
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await res.json();

                console.log(data);

                if (data.errors) {
                    emailError.textContent = data.errors.email;
                    passwordError.textContent = data.errors.password;
                }
                if (data.email) {
                    // Check if the logged-in user is the admin
                    if (data.email === 'admin@kkumail.com') {
                        // Redirect to the admin page
                        location.assign('/admin');
                    } else {
                        // Redirect to the home page for regular users
                        location.assign('/home-login');
                    }
                }

            }

             catch (err) {
            console.log(err);
        }
        });
    </script>
    <%- include('./partials/footer.ejs') %>

</body>
</html>