<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- logo -->
    <link rel="icon" type="image/png"
        href="https://firebasestorage.googleapis.com/v0/b/mbwproject-78d38.appspot.com/o/Logo.png?alt=media&token=de0aac26-de6a-43c0-839d-9032323646cd&_gl=1*15y48q1*_ga*MTg1NDY0MDk2OC4xNjk2MzM4MjQ3*_ga_CW55HF8NVT*MTY5NjMzODI0Ny4xLjEuMTY5NjMzODYxNy40NC4wLjA." />
    <!-- bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
        <link rel="stylesheet" href="/stylesheets/bookmark.css">
    <title>Rotten Bananas Genre:...</title>
    <style>
        a {
            text-decoration: none;
        }
    </style>
 
</head>

<body>
    <%- include('../partials/nav.ejs') %>

    <section class="p-0 m-0 border-0  bd-example bd-example-row genre">
        <div class="row   mx-5 my-5">
            <h3 class="genree mb-5"><%= movieType %></h3>
            <!-- loop st -->
            <% movies.forEach(movie => { %>
            <div class="col-sm-6 col-md-4 col-xl-2 mb-5 m p-0 ">
                <a href="/moviedetail_nolog/<%= movie._id %>">
                    <div class="card border-0 ">
                        <img src="<%= movie.imgM %>"
                            class="img-genre " alt="ภาพยนตร์">
                        <div class="card-body  ps-0 m-0">
                            <h5 class="card-title text-black "><img src="https://firebasestorage.googleapis.com/v0/b/mbwproject-78d38.appspot.com/o/bananas.png?alt=media&token=f8a41b4c-1625-44b2-b3c5-08fb38c83a21&_gl=1*1vx0i2g*_ga*MTg1NDY0MDk2OC4xNjk2MzM4MjQ3*_ga_CW55HF8NVT*MTY5NjUyMzYzNS4xMy4xLjE2OTY1MjM2NjMuMzIuMC4w" alt="bananater" class="bananater"><p class="text namemov"><%= movie.title %></p>
                            </h5>
                            
                        </div>
                    </div>
                    
                </a>
                
            </div>
            <% }); %>
            <!-- loop end -->
        </div>

    </section>
    <%- include('../partials/footer.ejs') %>

    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
        integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
        crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"
        integrity="sha384-BBtl+eGJRgqQAUMxJ7pMwbEyER4l1g+O15P+16Ep7Q9Q+zqX6gSbd85u4mG4QzX+"
        crossorigin="anonymous"></script>

</body>

</html>