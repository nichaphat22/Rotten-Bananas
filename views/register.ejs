<body class="m-0 p-0">
    <%- include('./partials/nav.ejs') %>
    <div class="container">
        <div class="row justify-content-md-center">
            <div class="col-lg-6 mt-5">
                <img src="/images/logo.jpg" width="160" height="160" class="image1">
                <h3 class="regis">ลงทะเบียน</h3>

                <form  class="register-form" id="register-form">
                    <div class="form-group">
                        <i class="fa-solid fa-user"></i>
                        <input type="text" name="username" id="name" placeholder="ชื่อผู้ใช้" required>
                    </div>
                    <hr>

                    <div class="form-group">
                        <i class="fa-solid fa-envelope"></i>
                        <input type="text" name="email" id="email" placeholder="Email" required>
                        <div class="email error"></div>
                    </div>
                    <hr>

                    <div class="form-group">
                        <i class="fa-solid fa-venus-mars"></i>
                        <select class="select" name="gender" id="Select1" required>
                            <option selected disabled>เพศ</option>
                            <option value="ชาย">ชาย</option>
                            <option value="หญิง">หญิง</option>
                            <option value="LGBTQIA+">LGBTQIA+</option>
                            <option value="ไม่ระบุ">ไม่ระบุ</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <i class="fa-solid fa-unlock-keyhole"></i>
                        <input type="password" name="password" id="password" placeholder="รหัสผ่าน" required>
                        <div class="password error"></div>
                    </div>
                    <hr>
                   
                    
                    <div class="regis-btm regis-button form-group">
                        <input type="submit" value="ลงทะเบียน" id="submit">
                    </div>
                </form>
            </div>

            <div class="col-lg-6 mt-5 text-center">
                <img src="https://firebasestorage.googleapis.com/v0/b/mbwproject-78d38.appspot.com/o/bananatree.jpg?alt=media&token=bfff4da5-31d3-4283-89b8-5258f93f6743&_gl=1*7sc9o*_ga*MTg1NDY0MDk2OC4xNjk2MzM4MjQ3*_ga_CW55HF8NVT*MTY5NjM1OTEwNS41LjEuMTY5NjM1OTExNC41MS4wLjA."
                alt="bananarotten" class="bnnregis mb-5 ">
                <p class="undr ">คุณเป็นสมาชิกแล้วใช่ไหม? <a class="grn" href="/login">เข้าสู่ระบบที่นี่</a></p>
            </div>

        </div>

    </div>

    <script>

        const form = document.querySelector('.container form');
        const emailError = document.querySelector('.email.error');
        const passwordError = document.querySelector('.password.error');
        const submitButton = document.querySelector('#submit');


        submitButton.addEventListener('click', async (e) => {
            e.preventDefault();

            // Reset errors
            emailError.textContent = '';
            passwordError.textContent = '';

            // Get the values
            const username = form.username.value;
            const email = form.email.value;
            const password = form.password.value;
            const gender = form.gender.value;
            

            try {
                const res = await fetch('/register', {
                    method: 'POST',
                    body: JSON.stringify({ username,email, password,gender}),
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await res.json();

                console.log(data);

                if (data.errors) {
                    emailError.textContent = data.errors.email;
                    passwordError.textContent = data.errors.password;
                }
                if (data.users) {
                    // Redirect to the home page
                    location.assign('/home-login');
                    
                }

            } catch (err) {
                console.log(err);
            }
        });
    </script>
    <%- include('./partials/footer.ejs') %>
</body>

