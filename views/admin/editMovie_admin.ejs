<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png"
        href="https://firebasestorage.googleapis.com/v0/b/mbwproject-78d38.appspot.com/o/Logo.png?alt=media&token=de0aac26-de6a-43c0-839d-9032323646cd&_gl=1*15y48q1*_ga*MTg1NDY0MDk2OC4xNjk2MzM4MjQ3*_ga_CW55HF8NVT*MTY5NjMzODI0Ny4xLjEuMTY5NjMzODYxNy40NC4wLjA." />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="/stylesheets/admin.css">
    <title>Rotten Bananas - Edit_movie</title>
    <!-- nav -->
    <link rel="stylesheet" href="/stylesheets/navAdmin.css">
    <link rel="stylesheet"
        href="https://maxst.icons8.com/vue-static/landings/line-awesome/line-awesome/1.3.0/css/line-awesome.min.css">

</head>

<body>
    <%- include('../partials/navAdmin.ejs') %>
        <div class="main-content ">
            <div class="container-main">
                <div class="headad">
                    <h1>แก้ไขภาพยนตร์</h1>
                </div>
                

                <div class="imgmv">
                    <img class="img-movie" src="<%= movies.imgM %>" alt="โปสเตอร์">
                </div>


                <div class="infor">
                    <form action="/admin/updateMovie/<%= movies._id %>" method="post">
                        <input type="text" id="namemovie" name="title" placeholder="ชื่อภาพยนตร์" value="<%= movies.title %>">
                        <select class="form-select" name="type" aria-label="Default select example">
                            <option hidden><%= movies.type %></option>
                            <option value="การตูนอนิเมชั่น (Animation)">การตูนอนิเมชั่น (Animation)</option>
                            <option value="นิยายเหนือจริง (Fantasy)">นิยายเหนือจริง (Fantasy)</option>
                            <option value="แอ็คชั่น (Action)">แอ็คชั่น (Action)</option>
                            <option value="ตลก (Comedy)">ตลก (Comedy)</option>
                            <option value="ชีวิต (Drama)">ชีวิต (Drama)</option>
                            <option value="หนังผี (Horror)">หนังผี (Horror)</option>
                            <option value="นวนิยายวิทยาศาสตร์ (Sci-fi)">นวนิยายวิทยาศาสตร์ (Sci-fi)</option>
                            <option value="รักโรแมนติก (Romance)">รักโรแมนติก (Romance)</option>
                        </select>
                        <textarea name="detail" placeholder="รายละเอียดภาพยนตร์"><%= movies.detail %></textarea>
                        <input type="text" name="imgM"placeholder="โปสเตอร์" value="<%= movies.imgM %>">
                        <input type="text" id="yearmovie" class="yearmovie" name="year" placeholder="ปีที่ฉาย" value="<%= movies.year %>">
                        <div class="bananater">
                            <img src="https://firebasestorage.googleapis.com/v0/b/mbwproject-78d38.appspot.com/o/bananas.png?alt=media&token=f8a41b4c-1625-44b2-b3c5-08fb38c83a21&_gl=1*1vx0i2g*_ga*MTg1NDY0MDk2OC4xNjk2MzM4MjQ3*_ga_CW55HF8NVT*MTY5NjUyMzYzNS4xMy4xLjE2OTY1MjM2NjMuMzIuMC4w&fbclid=IwAR2S1ycoHB6hZ4nQl1mXPCLgEiG7-PqcEXHEgTUCVVB_1gXSkslsOsqoxGg"
                                alt="กล้วยอร่อย">

                            <input type="text" id="score">
                        </div>
                        <label>BANANATER</label>
                        <button type="submit">ยืนยันการแก้ไข</button>
                    </form>
                </div>
            </div>
            <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
                integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
                crossorigin="anonymous"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"
                integrity="sha384-BBtl+eGJRgqQAUMxJ7pMwbEyER4l1g+O15P+16Ep7Q9Q+zqX6gSbd85u4mG4QzX+"
                crossorigin="anonymous"></script>
            <script>
              

            </script>
        </div>


</body>

</html>