<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1">
    <!-- logo -->
    <link rel="icon" type="image/png"
        href="https://firebasestorage.googleapis.com/v0/b/mbwproject-78d38.appspot.com/o/Logo.png?alt=media&token=de0aac26-de6a-43c0-839d-9032323646cd&_gl=1*15y48q1*_ga*MTg1NDY0MDk2OC4xNjk2MzM4MjQ3*_ga_CW55HF8NVT*MTY5NjMzODI0Ny4xLjEuMTY5NjMzODYxNy40NC4wLjA." />
    <!-- bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <!-- css -->
    <link rel="stylesheet" href="/stylesheets/admin.css">
    <!-- <link rel="stylesheet" type="text/css" href="/css/all.css"> -->
    <title>Rotten Bananas - Login</title>
    <link rel="stylesheet" href="/stylesheets/navAdmin.css">
    <link rel="stylesheet"
        href="https://maxst.icons8.com/vue-static/landings/line-awesome/line-awesome/1.3.0/css/line-awesome.min.css">

</head>

<body>
    <%- include('../partials/navAdmin.ejs') %>
        <div class="main-content ">
            <div class="container-main">
                <div class="headad">
                    <h1>HOME</h1>
                    <h4>ประวัติการจัดการข้อมูล</h4>
                </div>
                <div class="table_p">
                    <table>
                        <tr>
                            <th di="f">ID</th>
                            <th>ข้อมูล</th>
                            <th></th>
                            <th>วัน เวลา ที่จัดการข้อมูล</th>
                        </tr>
                        <% if (results.length===0) { %>
                            <p>ไม่พบข้อมูล</p>
                            <% } else { %>
                                <% results.forEach((item, index)=> { %>
                                    <tr>
                                        <td id="id">
                                            <%= index + 1 %>
                                        </td>
                                        <td>
                                            <%= item.title %>
                                        </td>
                                        <td></td>
                                        <td>
                                            <%= item.createdAt %>
                                        </td>
                                    </tr>
                                    <% }); %>
                                        <% } %>
                    </table>
                </div>
            </div>

        </div>
        <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
            integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
            crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"
            integrity="sha384-BBtl+eGJRgqQAUMxJ7pMwbEyER4l1g+O15P+16Ep7Q9Q+zqX6gSbd85u4mG4QzX+"
            crossorigin="anonymous"></script>
</body>

</html>