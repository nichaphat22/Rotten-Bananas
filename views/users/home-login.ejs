<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rotten Bananas - Home</title>
  <!-- logo -->
  <link rel="icon" type="image/png"
    href="https://firebasestorage.googleapis.com/v0/b/mbwproject-78d38.appspot.com/o/Logo.png?alt=media&token=de0aac26-de6a-43c0-839d-9032323646cd&_gl=1*15y48q1*_ga*MTg1NDY0MDk2OC4xNjk2MzM4MjQ3*_ga_CW55HF8NVT*MTY5NjMzODI0Ny4xLjEuMTY5NjMzODYxNy40NC4wLjA." />
  <!-- boostrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
  <link rel="stylesheet" href="/stylesheets/home-not-login.css">
</head>

<body class="m-0 p-0">
    <%- include('../partials/navlogin.ejs') %>
    <div id="carouselExampleIndicators" class="carousel slide">
      <div class="carousel-indicators">
        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="0" class="active"
          aria-current="true" aria-label="Slide 1"></button>
        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="1"
          aria-label="Slide 2"></button>
        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="2"
          aria-label="Slide 3"></button>
      </div>
      <div class="carousel-inner">
        <div class="carousel-item active">
          <img
            src="https://1.bp.blogspot.com/-sw7b2yg7t58/YOSr0OKJsOI/AAAAAAAAOj0/QTZsZCwmA70pLsKXRu-STrDzyihxfrnOwCLcBGAsYHQ/s2046/Screen%2BShot%2B2021-07-06%2Bat%2B12.15.05%2BPM.png"
            class="d-block w-100" alt="...">
        </div>
        <div class="carousel-item">
          <img
            src="https://prod-ripcut-delivery.disney-plus.net/v1/variant/disney/1D21EF8E5EED0250916B29EE30DBAB1B249B1CEF04C63C86E17B71EB8E6C771A/scale?width=1200&aspectRatio=1.78&format=jpeg"
            class="d-block w-100" alt="...">
        </div>
        <div class="carousel-item">
          <img src="https://static1.colliderimages.com/wordpress/wp-content/uploads/2022/01/Turning-Red.jpg"
            class="d-block w-100" alt="...">
        </div>
      </div>
      <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators"
        data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators"
        data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
      </button>
    </div>
    <% if (moviesByType) { %>
    <div id="homepage">
      <div class="contenthome">
        <% for (const type in moviesByType) { %>
          <a href="/movies_login/<%= type %>" id="link-mv">
            <h3 id="movie"><span id="s1">&#124;</span> <%= type %> <span id="s2">&#9002;</span></h3>
          </a>
          <div class="container text-center">
            <div class="row align-items-start">
              <% const movies = moviesByType[type].slice(0, 3); %>
              <% movies.forEach(movie => { %>
                <div class="col">
                  <div class="card" style="width: 12rem; height: 28rem;" id="card">
                    <a href="/moviedetail_log/<%= movie._id %>">
                      <img src="<%= movie.imgM %>" class="card-img-top" alt="..." id="img-home">
                      <div class="card-body" id="m1">
                        <h5 class="card-title" id="title"><img class="banana" src="/images/384828816_6500833120025287_3973906044799210284_n.png" alt="#"><%= movie.rating %></h5>
                        <!-- <p class="name-mv">The Chosen One</p>
                        <form action="#" method="POST">
                          <button type="submit" class="btn" id="save">บันทึกรายการ</button>
                        </form> -->
                      </div>
                      <h5><%= movie.title %></h5>
                    </a>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
          <hr>
        <% } %>
      </div>
    </div>
    <% } else { %>
      <!-- กรณีไม่มีข้อมูล moviesByType -->
      <p>No movies available</p>
    <% } %>
    





    <%- include('../partials/footerlogin.ejs') %>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous">
        </script>
</body>

</html>